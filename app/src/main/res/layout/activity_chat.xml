<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5a3a3"
    tools:context=".ChatActivity"
    tools:ignore="TouchTargetSize" >

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="16dp"
        tools:ignore="TouchTargetSize" >

        <!-- Iconul pentru setări -->
        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_margin="16dp"
            android:contentDescription="Settings Icon"
            android:src="@drawable/icon_setting"
            app:tint="@color/white"
            tools:ignore="TouchTargetSize" />


        <!-- Titlul "Discussions" -->
        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:text="Discussions"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:ignore="TouchTargetSize" />

        <!-- Iconul pentru meniu (cele trei linii) -->
        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="16dp"
            android:contentDescription="Menu Icon"
            android:src="@drawable/ic_menu"
            app:tint="@color/white"
            tools:ignore="TouchTargetSize" />


        <!-- RecyclerView pentru lista de topicuri -->


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/bottomNavigation"
            android:layout_below="@id/titleTextView"
            android:layout_margin="16dp"
            android:layout_marginTop="34dp"
            android:layout_marginBottom="-2dp"
            tools:listitem="@layout/background_ic"
            tools:ignore="TouchTargetSize" />

        <RelativeLayout
            android:id="@+id/startNewTopicLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="16dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="54dp"
            android:background="@drawable/background_bottomm"
            android:padding="8dp"
            tools:ignore="TouchTargetSize" >

            <!-- Textul "Want to start a new topic?" -->

            <!-- Butonul "+" pentru crearea unui topic nou -->
            <TextView
                android:id="@+id/startNewTopicText"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_marginStart="93dp"
                android:text="Want to start a new topic?"
                android:textColor="@color/white"
                android:textSize="14sp"
                tools:ignore="TouchTargetSize" />

            <ImageButton
                android:id="@+id/fab_create_topic"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackground"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="15dp"
                android:contentDescription="Create new topic"
                android:src="@drawable/ic_add"
                app:maxImageSize="24dp"
                tools:ignore="TouchTargetSize" />

        </RelativeLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="39dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bottom_background"
            android:elevation="15dp"
            android:paddingLeft="10dp"
            app:itemIconSize="30dp"
            app:itemIconTint="@drawable/item_selector"
            app:itemRippleColor="@android:color/transparent"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/buttonnavmenu">

        </com.google.android.material.bottomnavigation.BottomNavigationView>

    </RelativeLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
