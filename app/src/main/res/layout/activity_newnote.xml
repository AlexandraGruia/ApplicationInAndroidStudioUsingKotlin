<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5a3a3"
    tools:context=".NewNoteActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_margin="16dp"
            android:src="@drawable/icon_setting"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:contentDescription="Settings Icon"
            app:tint="@color/white" />

        <!-- Date Title -->
        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monday, March 09"
            android:textSize="18sp"
            android:textColor="#333"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:id="@+id/iconRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/dateText"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center">


            <ImageButton
                android:id="@+id/photoButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_photo"
                android:contentDescription="Add or Take Photo"
                android:layout_margin="8dp" />

            <ImageButton
                android:id="@+id/stickersButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_sticker"
                android:contentDescription="Stickers"
                android:layout_margin="8dp" />

            <ImageButton
                android:id="@+id/drawButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/ic_drawing"
                android:contentDescription="Draw"
                android:layout_margin="8dp"
                />
       </LinearLayout>


        <!-- ImageView to show the drawing -->
        <ImageView
            android:id="@+id/savedDrawingImageView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:visibility="gone" />

        <!-- EditText pentru text și imagini -->
        <EditText
            android:id="@+id/postInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_below="@id/iconRow"
            android:layout_margin="16dp"
            android:background="@drawable/rounded_input"
            android:gravity="top|start"
            android:hint="Start writing..."
            android:inputType="textMultiLine"
            android:minHeight="150dp"
            android:scrollbars="vertical"
            android:padding="10dp" />


        <!-- "Is that all?" Message -->
        <TextView
            android:id="@+id/questionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/postInput"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="Is that all?"
            android:textSize="16sp"
            android:textColor="#666" />

        <!-- Adjust submit button -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/questionText"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="Yes"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:background="@drawable/rounded_button"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />


        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_gravity="bottom"
            android:background="@drawable/bottom_background"
            android:elevation="15dp"
            app:itemIconSize="30dp"
            android:paddingLeft="10dp"
            android:focusableInTouchMode="true"
            app:itemIconTint="@drawable/item_selector"
            app:itemRippleColor="@android:color/transparent"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/buttonnavmenu" />

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

